{
  "manifest_version": 3,
  "name": "Jobmaster",
  "version": "0.2.3",
  "description": "Track jobs, manage candidate data, generate materials, and autofill applications.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "downloads",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Jobmaster",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/platforms.js",
        "src/content/autofill-core.js",
        "src/content/autofill.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
